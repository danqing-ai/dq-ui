{
  "name": "@danqing/dq-shell",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "npm run clean && vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist && printf \"%s\\n\" \"export * from './shell/src/index';\" > dist/index.d.ts",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "@danqing/dq-ui": "^0.1.0"
  },
  "dependencies": {
    "@danqing/dq-ui": "file:../ui"
  },
  "devDependencies": {
    "vue": "^3.5.13",
    "typescript": "^5.6.3"
  },
  "files": ["dist"]
}
