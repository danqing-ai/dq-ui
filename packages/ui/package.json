{
  "name": "@danqing/dq-ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "npm run clean && vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "lucide-vue-next": "^0.468.0",
    "reka-ui": "^2.9.7"
  },
  "devDependencies": {
    "vue": "^3.5.13",
    "typescript": "^5.6.3"
  },
  "files": ["dist"]
}
