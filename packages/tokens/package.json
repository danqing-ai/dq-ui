{
  "name": "@danqing/dq-tokens",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "npm run clean && node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
