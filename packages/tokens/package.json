    "./dq-mac.css": "./dist/dq-mac.css",
    "./dq-glass.css": "./dist/dq-glass.css",
    "./dq-linear-dark.css": "./dist/dq-linear-dark.css",
    "./dq-china-red-dark.css": "./dist/dq-china-red-dark.css",
    "./dq-shadcn-dark.css": "./dist/dq-shadcn-dark.css",
    "./dq-shadcn-light.css": "./dist/dq-shadcn-light.css",
    "./dq-catppuccin.css": "./dist/dq-catppuccin.css",
    "./dq-tokyo-night.css": "./dist/dq-tokyo-night.css",
    "./dq-minimal-light.css": "./dist/dq-minimal-light.css",
    "./dq-dracula.css": "./dist/dq-dracula.css",
    "./dq-nord-dark.css": "./dist/dq-nord-dark.css",
    "./dq-catppuccin-latte.css": "./dist/dq-catppuccin-latte.css",
    "./dq-nord-light.css": "./dist/dq-nord-light.css",
    "./dq-github-light.css": "./dist/dq-github-light.css",
    "./dq-tauri-macos.css": "./dist/dq-tauri-macos.css",
    "./dq-typography.css": "./dist/dq-typography.css",
    "./dq-agent.css": "./dist/dq-agent.css"
  },
  "files": ["dist"]
